# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/leados?schema=public"

# --- App ---
APP_URL="http://localhost:3000"
ADMIN_PASSWORD="change-me"          # Basic auth gate for the admin UI
CRON_SECRET="change-me"             # Required header for /api/cron/*

# --- Facebook / Meta ---
FACEBOOK_PAGE_ACCESS_TOKEN=""
FACEBOOK_WEBHOOK_VERIFY_TOKEN=""
META_APP_SECRET=""

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# --- Email provider ---
# Preferred: Resend HTTP API (works on Railway, which blocks SMTP). Send from a
# domain verified in Resend. EMAIL_FROM overrides SMTP_FROM for the from address.
RESEND_API_KEY=""
EMAIL_FROM="OS4ER Leads <leads@onestop4equityrelease.co.uk>"
# Legacy fallback: Brevo HTTP API (used only if RESEND_API_KEY is unset).
BREVO_API_KEY=""

# --- SMTP (Email) ---  local fallback; leave blank to use console-stub mode
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="LeadOS <leads@example.com>"

# --- After-hours admin / Craig ---
ADMIN_EMAIL="admin@example.com"
CRAIG_PHONE=""                      # Backend SMS recipient for after-hours mode A

# --- AI ---
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Zapier ingest ---
ZAPIER_INGEST_SECRET=""
